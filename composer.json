{
    "name": "yourvendor/laravel-audit-trail",
    "description": "Fluent, diff-aware audit trail for Eloquent models — with multi-tenant support and a swappable driver system.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "audit", "trail", "log", "eloquent", "diff", "history"],
    "authors": [
        {
            "name": "Your Name",
            "email": "you@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/database": "^10.0|^11.0",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/queue": "^10.0|^11.0",
        "illuminate/events": "^10.0|^11.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "pestphp/pest": "^2.0",
        "pestphp/pest-plugin-laravel": "^2.0",
        "laravel/pint": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "YourVendor\\AuditTrail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "YourVendor\\AuditTrail\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "YourVendor\\AuditTrail\\AuditServiceProvider"
            ],
            "aliases": {
                "Auditor": "YourVendor\\AuditTrail\\Facades\\Auditor"
            }
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest",
        "lint": "./vendor/bin/pint"
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
